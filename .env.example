# =====================================================================
# Gym ERP - Environment configuration template
# =====================================================================
# Copy to ".env" and adjust. ALL values are optional: the application
# ships with safe cross-platform defaults and runs fully offline without
# any of these set. Never commit a real ".env" (see .gitignore).
#
# Every key is prefixed GYM_ERP_ and maps 1:1 to app.settings.config.AppConfig.
# Nested settings use a double underscore, e.g. GYM_ERP_DATABASE__URL.
# =====================================================================

# --- General -------------------------------------------------------
# Environment: "production" | "development" | "test"
GYM_ERP_ENVIRONMENT=production
# UI language: "en" (LTR) or "ar" (RTL)
GYM_ERP_LANGUAGE=en
# UI theme: "dark" | "light" | "system"
GYM_ERP_THEME=system

# --- Database ------------------------------------------------------
# Leave blank to use the default local SQLite file in the app data dir.
# For a future PostgreSQL upgrade use a full SQLAlchemy URL, e.g.:
#   postgresql+psycopg://user:pass@localhost:5432/gym_erp
GYM_ERP_DATABASE__URL=
# Echo SQL to logs (development only)
GYM_ERP_DATABASE__ECHO=false

# --- Security ------------------------------------------------------
# Optional override for the data directory that stores DB, backups, logs,
# photos and the local encryption key. Defaults to the OS app-data folder.
GYM_ERP_DATA_DIR=

# --- Logging -------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
GYM_ERP_LOGGING__LEVEL=INFO
